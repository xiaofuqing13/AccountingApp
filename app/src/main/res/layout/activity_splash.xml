<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 全屏背景层，使用 centerCrop 自动裁剪掉画面的左右留白 -->
    <ImageView
        android:id="@+id/img_bg_full"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_splash_full"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 1 - 左上 -->
    <ImageView
        android:id="@+id/heart_float_1"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="120dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 2 - 右上 -->
    <ImageView
        android:id="@+id/heart_float_2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="50dp"
        android:layout_marginTop="180dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 3 - 左下 -->
    <ImageView
        android:id="@+id/heart_float_3"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="60dp"
        android:layout_marginBottom="260dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 浮动爱心 4 - 右下 -->
    <ImageView
        android:id="@+id/heart_float_4"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="320dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_88"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:id="@+id/logo_holder"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_splash_logo_holder"
            android:elevation="4dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/tv_logo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_love_heart"
                app:tint="@color/text_white" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:letterSpacing="0.06"
            android:text="@string/splash_title"
            android:textColor="@color/pink_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:shadowColor="@color/text_white"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="8" />

        <TextView
            android:id="@+id/tv_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.04"
            android:text="@string/splash_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:shadowColor="@color/text_white"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6" />

        <TextView
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="40dp"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_button_pink"
            android:gravity="center"
            android:text="@string/splash_enter"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="4dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:letterSpacing="0.06"
        android:text="@string/splash_footer"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:shadowColor="@color/text_white"
        android:shadowDx="0"
        android:shadowDy="1"
        android:shadowRadius="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
