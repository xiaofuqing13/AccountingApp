<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_pink">

    <!-- 装饰性圆形 左上 -->
    <View
        android:id="@+id/bg_decor_1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.2"
        android:background="@drawable/bg_tag_chip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 装饰性圆形 右下 -->
    <View
        android:id="@+id/bg_decor_2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginEnd="-44dp"
        android:layout_marginBottom="-56dp"
        android:alpha="0.18"
        android:background="@drawable/bg_tag_chip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 浮动爱心 1 - 左上 -->
    <ImageView
        android:id="@+id/heart_float_1"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="120dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 2 - 右上 -->
    <ImageView
        android:id="@+id/heart_float_2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="50dp"
        android:layout_marginTop="180dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 3 - 左下 -->
    <ImageView
        android:id="@+id/heart_float_3"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="60dp"
        android:layout_marginBottom="200dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 浮动爱心 4 - 右下 -->
    <ImageView
        android:id="@+id/heart_float_4"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="260dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_88"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 中心发光爱心 -->
    <ImageView
        android:id="@+id/iv_main_icon"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_main"
        android:layout_marginBottom="32dp"
        app:layout_constraintVertical_bias="0.45"
        app:layout_constraintBottom_toTopOf="@id/tv_app_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- 应用标题 -->
    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:alpha="0"
        android:letterSpacing="0.05"
        android:text="@string/splash_title"
        android:textColor="@color/text_primary"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tv_desc"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_main_icon" />

    <!-- 描述语 -->
    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="42dp"
        android:alpha="0"
        android:letterSpacing="0.08"
        android:text="@string/splash_desc"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        app:layout_constraintBottom_toTopOf="@id/btn_start"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_app_name" />

    <!-- 开始按钮 -->
    <TextView
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="60dp"
        android:layout_marginBottom="24dp"
        android:alpha="0"
        android:background="@drawable/bg_button_pink"
        android:gravity="center"
        android:text="@string/splash_enter"
        android:textColor="@color/text_white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tv_footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 底部说明 -->
    <TextView
        android:id="@+id/tv_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:letterSpacing="0.1"
        android:text="@string/splash_footer"
        android:textColor="@color/white_alpha_88"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
