<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_pink">

    <!-- 装饰性圆形 左上 -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginStart="-60dp"
        android:layout_marginTop="-80dp"
        android:alpha="0.2"
        android:background="@drawable/bg_tag_chip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 装饰性圆形 右下 -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginEnd="-44dp"
        android:layout_marginBottom="-56dp"
        android:alpha="0.18"
        android:background="@drawable/bg_tag_chip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 浮动爱心 1 - 左上 -->
    <ImageView
        android:id="@+id/heart_float_1"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="120dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 2 - 右上 -->
    <ImageView
        android:id="@+id/heart_float_2"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="50dp"
        android:layout_marginTop="180dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 浮动爱心 3 - 左下 -->
    <ImageView
        android:id="@+id/heart_float_3"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="60dp"
        android:layout_marginBottom="200dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 浮动爱心 4 - 右下 -->
    <ImageView
        android:id="@+id/heart_float_4"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="260dp"
        android:alpha="0"
        android:src="@drawable/ic_splash_heart"
        app:tint="@color/white_alpha_88"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_splash"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        app:cardBackgroundColor="@color/white_alpha_dd"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/white_alpha_55"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="30dp">

            <FrameLayout
                android:id="@+id/logo_holder"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_splash_logo_holder">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/tv_logo"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_love_heart"
                    app:tint="@color/text_white" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.06"
                android:text="@string/splash_title"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:letterSpacing="0.04"
                android:text="@string/splash_desc"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_start"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_pink"
                android:gravity="center"
                android:text="@string/splash_enter"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        android:letterSpacing="0.06"
        android:text="@string/splash_footer"
        android:textColor="@color/white_alpha_bb"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
