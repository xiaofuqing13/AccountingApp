<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_pink"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="36dp"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="功能设置"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="数据与备份"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/caption_size"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_settings_group"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/btn_export"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_export"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="导出备份"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_hint" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_import"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_nav_account"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="导入备份"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_hint" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_import_legacy"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_stats"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="导入旧版备份"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_hint" />
            </LinearLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_storage_path"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_nav_home"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="存储位置"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <TextView
                    android:id="@+id/tv_storage_path"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:ellipsize="start"
                    android:gravity="end"
                    android:maxLines="1"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/caption_size" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_auto_backup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="自动备份"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_auto_backup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/lavender" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="通用"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/caption_size"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_settings_group"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_love_heart"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="主题"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="少女粉"
                    android:textColor="@color/pink_primary"
                    android:textSize="@dimen/caption_size" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_dark_mode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_mood"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="深色模式"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_notification"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_love_shine"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="消息提醒"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_nav_settings"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="隐私锁"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_hint" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <View
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:background="@color/income_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="关于"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/caption_size"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_settings_group"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/tv_version"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_stats"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="版本信息"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <TextView
                    android:id="@+id/tv_version_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/caption_size" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_feedback"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_export"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="意见反馈"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/body_size" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_hint" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/divider"
                android:layout_marginStart="48dp" />

            <LinearLayout
                android:id="@+id/btn_love_menu"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/page_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_love_heart"
                    app:tint="@color/pink_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="情话小屋"
                    android:textColor="@color/pink_primary"
                    android:textSize="@dimen/body_size"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/pink_primary" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="用爱编写 · 我们的小账本"
            android:textColor="@color/footer_hint"
            android:textSize="10sp" />

    </LinearLayout>
</ScrollView>
