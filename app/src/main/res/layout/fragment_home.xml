<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Banner 渐变头部 -->
        <LinearLayout
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_pink"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_greeting_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#DDFFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#BBFFFFFF"
                android:textSize="12sp" />

            <!-- 实时计时器卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_rounded"
                android:backgroundTint="#22FFFFFF"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_counter_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="365"
                        android:textColor="@color/text_white"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="天"
                        android:textColor="#BBFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textColor="#88FFFFFF"
                    android:textSize="22sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_counter_hours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08"
                        android:textColor="@color/text_white"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="小时"
                        android:textColor="#BBFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textColor="#88FFFFFF"
                    android:textSize="22sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_counter_mins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="23"
                        android:textColor="@color/text_white"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="分钟"
                        android:textColor="#BBFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textColor="#88FFFFFF"
                    android:textSize="22sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_counter_secs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45"
                        android:textColor="@color/text_white"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="秒"
                        android:textColor="#BBFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 统计卡片区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingTop="14dp"
            android:paddingBottom="6dp">

            <!-- 在一起天数 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_days"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_stat_card_expense"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💕" android:textSize="22sp" />
                    <TextView android:id="@+id/tv_stat_days" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="365" android:textColor="@color/pink_primary" android:textSize="26sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_days_label" android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 本月日记 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_stat_card_balance"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📖" android:textSize="22sp" />
                    <TextView android:id="@+id/tv_stat_diary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#7E57C2" android:textSize="26sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_diary_count" android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 本月记账 -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_stat_card_income"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰" android:textSize="22sp" />
                    <TextView android:id="@+id/tv_stat_account" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/income_green" android:textSize="26sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_account_count" android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- 每日情话卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_daily_love"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/page_margin"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_love_card"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💌 今日情话"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_daily_love_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="32sp" />

                <TextView
                    android:id="@+id/tv_daily_love_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_daily_love_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:maxLines="4"
                    android:ellipsize="end"
                    android:textColor="#EEFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="点击查看完整情话 →"
                    android:textColor="#BBFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 快捷操作标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingTop="14dp"
            android:paddingBottom="6dp">

            <View
                android:layout_width="3dp"
                android:layout_height="16dp"
                android:background="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/home_quick"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 快捷操作网格 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingBottom="4dp"
            android:useDefaultMargins="true">

            <TextView android:id="@+id/btn_quick_account" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:background="@drawable/bg_home_quick_btn" android:elevation="2dp" android:gravity="center" android:padding="14dp" android:text="✏️\n记一笔" android:textColor="@color/text_primary" android:textSize="13sp" android:lineSpacingMultiplier="1.4" />
            <TextView android:id="@+id/btn_quick_diary" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:background="@drawable/bg_home_quick_btn" android:elevation="2dp" android:gravity="center" android:padding="14dp" android:text="📝\n写日记" android:textColor="@color/text_primary" android:textSize="13sp" android:lineSpacingMultiplier="1.4" />
            <TextView android:id="@+id/btn_quick_meeting" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:background="@drawable/bg_home_quick_btn" android:elevation="2dp" android:gravity="center" android:padding="14dp" android:text="🗓️\n记会议" android:textColor="@color/text_primary" android:textSize="13sp" android:lineSpacingMultiplier="1.4" />
            <TextView android:id="@+id/btn_quick_stats" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:background="@drawable/bg_home_quick_btn" android:elevation="2dp" android:gravity="center" android:padding="14dp" android:text="📊\n统计" android:textColor="@color/text_primary" android:textSize="13sp" android:lineSpacingMultiplier="1.4" />
            <TextView android:id="@+id/btn_quick_export" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:background="@drawable/bg_home_quick_btn" android:elevation="2dp" android:gravity="center" android:padding="14dp" android:text="📤\n导出Excel" android:textColor="@color/text_primary" android:textSize="13sp" android:lineSpacingMultiplier="1.4" />
            <TextView android:id="@+id/btn_quick_settings" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:background="@drawable/bg_home_quick_btn" android:elevation="2dp" android:gravity="center" android:padding="14dp" android:text="⚙️\n设置" android:textColor="@color/text_primary" android:textSize="13sp" android:lineSpacingMultiplier="1.4" />
        </GridLayout>

        <!-- 底部留白 -->
        <View android:layout_width="1dp" android:layout_height="16dp" />

    </LinearLayout>
</ScrollView>
