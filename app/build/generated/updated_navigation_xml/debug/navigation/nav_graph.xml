<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:id="@+id/nav_graph"
app:startDestination="@id/nav_home" >
<fragment
    android:id="@+id/nav_home"
    android:name="com.loveapp.accountbook.ui.home.HomeFragment"
    android:label="@string/nav_home" >

    <action
        android:id="@+id/action_home_to_account_add"
        app:destination="@id/nav_account_add" />
    <action
        android:id="@+id/action_home_to_diary_add"
        app:destination="@id/nav_diary_add" />
    <action
        android:id="@+id/action_home_to_meeting_add"
        app:destination="@id/nav_meeting_add" />
    <action
        android:id="@+id/action_home_to_account_stats"
        app:destination="@id/nav_account_stats" />

</fragment>
<fragment
    android:id="@+id/nav_account"
    android:name="com.loveapp.accountbook.ui.account.AccountListFragment"
    android:label="@string/nav_account" >

    <action
        android:id="@+id/action_account_to_add"
        app:destination="@id/nav_account_add" />
    <action
        android:id="@+id/action_account_to_stats"
        app:destination="@id/nav_account_stats" />

</fragment>
<fragment
    android:id="@+id/nav_account_add"
    android:name="com.loveapp.accountbook.ui.account.AccountAddFragment"
    android:label="@string/account_add" />
<fragment
    android:id="@+id/nav_account_stats"
    android:name="com.loveapp.accountbook.ui.account.AccountStatsFragment"
    android:label="@string/account_stats" />
<fragment
    android:id="@+id/nav_diary"
    android:name="com.loveapp.accountbook.ui.diary.DiaryListFragment"
    android:label="@string/nav_diary" >

    <action
        android:id="@+id/action_diary_to_add"
        app:destination="@id/nav_diary_add" />

</fragment>
<fragment
    android:id="@+id/nav_diary_add"
    android:name="com.loveapp.accountbook.ui.diary.DiaryAddFragment"
    android:label="@string/diary_add" >

    <argument
        android:name="entryRowIndex"
        android:defaultValue="-1"
        app:argType="integer" />
    <argument
        android:name="entryTitle"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryContent"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryWeather"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryMood"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryLocation"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryDate"
        android:defaultValue=""
        app:argType="string" />

</fragment>
<fragment
    android:id="@+id/nav_meeting"
    android:name="com.loveapp.accountbook.ui.meeting.MeetingListFragment"
    android:label="@string/nav_meeting" >

    <action
        android:id="@+id/action_meeting_to_add"
        app:destination="@id/nav_meeting_add" />

</fragment>
<fragment
    android:id="@+id/nav_meeting_add"
    android:name="com.loveapp.accountbook.ui.meeting.MeetingAddFragment"
    android:label="@string/meeting_add" >

    <argument
        android:name="entryRowIndex"
        android:defaultValue="-1"
        app:argType="integer" />
    <argument
        android:name="entryTopic"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryDate"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryStartTime"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryEndTime"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryLocation"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryAttendees"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryContent"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryTodoItems"
        android:defaultValue=""
        app:argType="string" />
    <argument
        android:name="entryTags"
        android:defaultValue=""
        app:argType="string" />

</fragment>
<fragment
    android:id="@+id/nav_settings"
    android:name="com.loveapp.accountbook.ui.settings.SettingsFragment"
    android:label="@string/nav_settings" >

    <action
        android:id="@+id/action_settings_to_love"
        app:destination="@id/nav_love_letter" />
    <action
        android:id="@+id/action_settings_to_love_menu"
        app:destination="@id/nav_love_menu" />

</fragment>
<fragment
    android:id="@+id/nav_love_letter"
    android:name="com.loveapp.accountbook.ui.love.LoveLetterFragment"
    android:label="@string/love_letter_title" />
<fragment
    android:id="@+id/nav_love_menu"
    android:name="com.loveapp.accountbook.ui.love.LoveMenuFragment"
    android:label="@string/love_menu_title" />
</navigation>