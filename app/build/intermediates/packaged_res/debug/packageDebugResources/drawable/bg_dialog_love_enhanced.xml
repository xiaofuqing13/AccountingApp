<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="@color/dialog_border_start" android:endColor="@color/dialog_border_end" android:angle="135"/>
            <corners android:radius="@dimen/radius_xl"/>
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_background"/>
            <corners android:radius="@dimen/radius_xl_inner"/>
        </shape>
    </item>
</layer-list>
