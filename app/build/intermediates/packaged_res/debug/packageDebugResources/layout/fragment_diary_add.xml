<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pink_primary"
        android:gravity="center_vertical"
        android:padding="@dimen/page_margin">
        <ImageButton android:id="@+id/btn_back" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_arrow_back" android:background="?android:attr/selectableItemBackgroundBorderless" app:tint="@color/text_white" android:padding="4dp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/diary_add" android:textColor="@color/text_white" android:textSize="@dimen/title_size" android:textStyle="bold" android:layout_marginStart="16dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diary_save"
            android:textColor="@color/text_white" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        app:cardCornerRadius="@dimen/card_radius_unified"
        app:cardElevation="@dimen/card_elevation_unified"
        app:cardBackgroundColor="@color/pink_card">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            
            <!-- 元数据标签 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView android:id="@+id/tag_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_chip" android:paddingHorizontal="10dp" android:paddingVertical="6dp" android:textSize="12sp" android:textColor="@color/pink_primary" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tag_weather" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_chip" android:paddingHorizontal="10dp" android:paddingVertical="6dp" android:textSize="12sp" android:textColor="@color/pink_primary" android:layout_marginEnd="8dp" />
                <TextView android:id="@+id/tag_mood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_chip" android:paddingHorizontal="10dp" android:paddingVertical="6dp" android:textSize="12sp" android:textColor="@color/pink_primary" />
            </LinearLayout>

            <!-- 天气选择器 -->
            <HorizontalScrollView
                android:id="@+id/weather_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/weather_chip_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    app:singleSelection="true"
                    app:chipSpacingHorizontal="8dp"
                    app:selectionRequired="true" />
            </HorizontalScrollView>

            <!-- 心情选择器 -->
            <HorizontalScrollView
                android:id="@+id/mood_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone">
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/mood_chip_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    app:singleSelection="true"
                    app:chipSpacingHorizontal="8dp"
                    app:selectionRequired="true" />
            </HorizontalScrollView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginHorizontal="12dp" />

            <!-- 标题 -->
            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="@string/diary_title_hint"
                android:padding="@dimen/page_margin"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- 内容区域（富内容预览 + 文本编辑） -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 编辑模式：已有图片/音频的富内容预览 -->
                    <LinearLayout
                        android:id="@+id/content_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/page_margin"
                        android:paddingTop="8dp"
                        android:visibility="gone" />

                    <!-- 文本编辑 -->
                    <EditText
                        android:id="@+id/et_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        android:background="@null"
                        android:gravity="top"
                        android:hint="@string/diary_content_hint"
                        android:padding="@dimen/page_margin"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="@dimen/body_size"
                        android:lineSpacingMultiplier="1.6" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 底部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/pink_card"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/page_margin"
        android:elevation="8dp">
        <ImageView android:id="@+id/btn_emoji" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_mood" app:tint="@color/pink_primary" android:layout_marginEnd="12dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:padding="8dp" />
        <ImageView android:id="@+id/btn_photo" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_camera" app:tint="@color/pink_primary" android:layout_marginEnd="12dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:padding="8dp" />
        <ImageView android:id="@+id/btn_voice" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_mic" app:tint="@color/pink_primary" android:layout_marginEnd="12dp" android:background="?android:attr/selectableItemBackgroundBorderless" android:padding="8dp" />
        <ImageView android:id="@+id/btn_tag" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_tag" app:tint="@color/pink_primary" android:background="?android:attr/selectableItemBackgroundBorderless" android:padding="8dp" />
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
        <ImageView android:id="@+id/btn_clear" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_delete" app:tint="@color/pink_primary" android:background="?android:attr/selectableItemBackgroundBorderless" android:padding="8dp" />
    </LinearLayout>
</LinearLayout>
