<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_audio_player"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:layout_marginVertical="8dp">

    <ImageView
        android:id="@+id/btn_play_pause"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="播放" />

    <com.loveapp.accountbook.ui.widget.VoiceWaveView
        android:id="@+id/voice_wave"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginStart="6dp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginHorizontal="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/pink_primary"
        android:thumbTint="@color/pink_primary"
        android:progressBackgroundTint="@color/pink_soft"
        android:minHeight="4dp"
        android:maxHeight="4dp" />

    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:minWidth="36dp"
        android:gravity="end" />
</LinearLayout>
