<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/pink_primary"
            android:gravity="center_vertical"
            android:padding="@dimen/page_margin">
            <ImageButton android:id="@+id/btn_back" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_arrow_back" android:background="?android:attr/selectableItemBackgroundBorderless" app:tint="@color/text_white" android:padding="4dp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/meeting_add" android:textColor="@color/text_white" android:textSize="@dimen/title_size" android:textStyle="bold" android:layout_marginStart="16dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/meeting_save"
                android:textColor="@color/text_white" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="@dimen/card_radius_unified"
            app:cardElevation="@dimen/card_elevation_unified"
            app:cardBackgroundColor="@color/pink_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_margin">

                <EditText 
                    android:id="@+id/et_topic" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:hint="@string/meeting_topic_hint" 
                    android:textSize="18sp" 
                    android:textStyle="bold" 
                    android:textColor="@color/text_primary" 
                    android:textColorHint="@color/text_hint" 
                    android:background="@null" 
                    android:paddingTop="4dp" 
                    android:paddingBottom="12dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="会议时间" android:textColor="@color/text_hint" android:textSize="@dimen/caption_size" android:layout_marginTop="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginTop="4dp">
                    <TextView android:id="@+id/tv_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_pink" android:padding="10dp" android:textColor="@color/text_primary" android:textSize="@dimen/body_size" />
                    <TextView android:id="@+id/tv_start_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_pink" android:padding="10dp" android:textColor="@color/text_primary" android:textSize="@dimen/body_size" android:layout_marginStart="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  至  " android:textColor="@color/text_hint" />
                    <TextView android:id="@+id/tv_end_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_pink" android:padding="10dp" android:textColor="@color/text_primary" android:textSize="@dimen/body_size" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginTop="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="会议地点" android:textColor="@color/text_hint" android:textSize="@dimen/caption_size" android:layout_marginTop="12dp" />
                <EditText 
                    android:id="@+id/et_location" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:hint="@string/meeting_location_hint" 
                    android:textSize="@dimen/body_size" 
                    android:textColor="@color/text_primary" 
                    android:textColorHint="@color/text_hint" 
                    android:background="@null" 
                    android:paddingVertical="8dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="参会人员" android:textColor="@color/text_hint" android:textSize="@dimen/caption_size" android:layout_marginTop="12dp" />
                <EditText 
                    android:id="@+id/et_attendees" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:hint="@string/meeting_attendee_hint" 
                    android:textSize="@dimen/body_size" 
                    android:textColor="@color/text_primary" 
                    android:textColorHint="@color/text_hint" 
                    android:background="@null" 
                    android:paddingVertical="10dp" />
                <com.google.android.material.chip.ChipGroup android:id="@+id/chip_attendees" android:layout_width="match_parent" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="@dimen/card_radius_unified"
            app:cardElevation="@dimen/card_elevation_unified"
            app:cardBackgroundColor="@color/pink_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/page_margin">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="会议内容" android:textColor="@color/text_hint" android:textSize="@dimen/caption_size" />
                <EditText 
                    android:id="@+id/et_content" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:hint="@string/meeting_content_hint" 
                    android:minLines="4" 
                    android:gravity="top" 
                    android:textSize="@dimen/body_size" 
                    android:textColor="@color/text_primary" 
                    android:textColorHint="@color/text_hint" 
                    android:background="@drawable/bg_tag_pink" 
                    android:padding="12dp" 
                    android:layout_marginTop="8dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="待办事项" android:textColor="@color/pink_primary" android:textSize="@dimen/caption_size" android:layout_marginTop="16dp" />
                <EditText 
                    android:id="@+id/et_todo" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:hint="@string/meeting_todo_hint" 
                    android:minLines="3" 
                    android:gravity="top" 
                    android:textSize="@dimen/body_size" 
                    android:textColor="@color/text_primary" 
                    android:textColorHint="@color/text_hint" 
                    android:background="@drawable/bg_tag_pink" 
                    android:padding="12dp" 
                    android:layout_marginTop="8dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="标签" android:textColor="@color/text_hint" android:textSize="@dimen/caption_size" android:layout_marginTop="16dp" />
                <com.google.android.material.chip.ChipGroup android:id="@+id/chip_tags" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
