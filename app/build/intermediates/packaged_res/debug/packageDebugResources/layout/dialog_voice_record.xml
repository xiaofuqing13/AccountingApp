<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_tag"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <!-- 拖拽把手 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:text="录音"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- 计时器 -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-light"
        android:text="00:00"
        android:textColor="@color/pink_primary"
        android:textSize="40sp" />

    <!-- 声波动画 -->
    <com.loveapp.accountbook.ui.widget.VoiceWaveView
        android:id="@+id/voice_wave"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="16dp" />

    <!-- 提示 -->
    <TextView
        android:id="@+id/tv_record_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="点击开始录音"
        android:textColor="@color/text_hint"
        android:textSize="13sp" />

    <!-- 录音按钮 -->
    <TextView
        android:id="@+id/btn_record_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_button_pink"
        android:drawablePadding="8dp"
        android:drawableStart="@drawable/ic_mic"
        android:drawableTint="@color/text_white"
        android:paddingHorizontal="28dp"
        android:paddingVertical="12dp"
        android:text="开始录音"
        android:textColor="@color/text_white"
        android:textSize="15sp" />

    <!-- 底部按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tag_chip"
            android:gravity="center"
            android:text="取消"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_done"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_pink"
            android:gravity="center"
            android:text="完成并插入"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
